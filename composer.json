{
    "name": "thaiduc96/llm-gateway",
    "description": "Production-grade, provider-agnostic LLM gateway for Laravel with automatic fallback, circuit breaker, and retry policies.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "llm", "gateway", "openai", "gemini", "fallback", "circuit-breaker"],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/contracts": "^10.0|^11.0",
        "illuminate/cache": "^10.0|^11.0",
        "illuminate/events": "^10.0|^11.0",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Thaiduc96\\LlmGateway\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Thaiduc96\\LlmGateway\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Thaiduc96\\LlmGateway\\LLMGatewayServiceProvider"
            ],
            "aliases": {
                "LLM": "Thaiduc96\\LlmGateway\\Facades\\LLM"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --no-progress"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
