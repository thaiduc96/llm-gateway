{
    "name": "thaiduc96/llm-gateway",
    "description": "Production-grade, provider-agnostic LLM gateway for Laravel with automatic fallback, circuit breaker, and retry policies.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "thaiduc96"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^8.0|^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Thaiduc96\\LlmGateway\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Thaiduc96\\LlmGateway\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
